# ZoraxyHub Configuration
# Copy this to .env.local and fill in values

# Admin credentials (set on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT secret for session tokens (generate a random 64-char string)
JWT_SECRET=change-this-to-a-random-64-character-string-for-production-use

# Master key for encrypting stored credentials (generate a random 32-char string)
MASTER_KEY=change-this-to-a-random-32-char-key

# Database path
DATABASE_PATH=./data/zoraxyhub.db

# Server
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Agent WebSocket server port
AGENT_WS_PORT=3001
