{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "openwork",
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "control-chrome": {
      "command": [
        "chrome-devtools-mcp"
      ],
      "type": "local"
    }
  },
  "plugin": [
    "opencode-scheduler"
  ],
  "disabled_providers": [
    "openai"
  ],
  "model": "enowxlabs/claude-opus-4.6"
}
